PORT=3001
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://postgres:postgres@localhost:5432/quizsaber
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=25
SYNC_FALLBACK=false
PROCESSING_FORCE_FALLBACK=false
FASTPATH_MIN_CONFIDENCE=0.9
FASTPATH_MIN_QUESTIONS=1
FASTPATH_MIN_QUESTION_CHARS=10
PIPELINE_PYTHON_BIN=python3
PIPELINE_ENTRYPOINT=../pipeline/main.py
PIPELINE_EXTRACT_MIN_CHARS=180
PIPELINE_GEMINI_MODEL=gemini-2.5-flash
PIPELINE_USE_MOCK_GEMINI=false
CLASSIFICATION_ENABLED=true
CLASSIFICATION_MODEL=gemini-2.5-flash
CLASSIFICATION_BATCH_SIZE=10
CLASSIFICATION_REQUEST_TIMEOUT_MS=30000
CLASSIFICATION_MAX_RETRIES=2
CLASSIFICATION_DAILY_USD_LIMIT=1
CLASSIFICATION_INPUT_USD_PER_1M=0.3
CLASSIFICATION_OUTPUT_USD_PER_1M=2.5
