{
  "name": "singular-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/jobs/process-exam.ts",
    "dev:worker:classification": "tsx watch src/jobs/process-classification.ts",
    "dev:workers": "concurrently --names \"exam,classification\" --prefix-colors \"cyan,green\" \"tsx watch src/jobs/process-exam.ts\" \"tsx watch src/jobs/process-classification.ts\"",
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "start": "node dist/index.js",
    "start:worker": "node dist/jobs/process-exam.js",
    "start:worker:classification": "node dist/jobs/process-classification.js",
    "start:workers": "concurrently --names \"exam,classification\" --prefix-colors \"cyan,green\" \"node dist/jobs/process-exam.js\" \"node dist/jobs/process-classification.js\""
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@hono/node-server": "^1.13.7",
    "bullmq": "^5.58.2",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.39.2",
    "hono": "^4.6.5",
    "ioredis": "^5.4.1",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@types/node": "^22.10.1",
    "@types/pdfjs-dist": "^2.10.377",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
