# Quizsaber — Environment Variables
# Copy to .env and fill in your values.
# For local/dev mode, only OCR_PROVIDER and OLLAMA_* are needed.

# ---------- Core Infrastructure ----------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/quizsaber
REDIS_URL=redis://localhost:6379
PORT=3001

# ---------- Upload ----------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=25

# ---------- OCR Provider ----------
# Options: "local" (Ollama, $0) | "api" (Gemini Flash) | "docling" (legacy)
OCR_PROVIDER=local

# --- Local mode (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_OCR_MODEL=glm-ocr
OLLAMA_OCR_FALLBACK_MODEL=qwen2.5vl:3b
OLLAMA_NUM_CTX=16384

# --- API mode (Gemini) ---
# GEMINI_API_KEY=your-key-here
# GOOGLE_API_KEY=your-key-here  # alternative

# ---------- Pipeline ----------
PIPELINE_PYTHON_BIN=python3
PIPELINE_ENTRYPOINT=../pipeline/main.py
PIPELINE_EXTRACT_MIN_CHARS=180
PIPELINE_GEMINI_MODEL=gemini-2.5-flash
PIPELINE_USE_MOCK_GEMINI=false

# ---------- LLM Classification ----------
CLASSIFICATION_ENABLED=true
CLASSIFICATION_MODEL=gemini-2.5-flash
CLASSIFICATION_BATCH_SIZE=10
CLASSIFICATION_REQUEST_TIMEOUT_MS=30000
CLASSIFICATION_MAX_RETRIES=2
CLASSIFICATION_DAILY_USD_LIMIT=1
CLASSIFICATION_INPUT_USD_PER_1M=0.3
CLASSIFICATION_OUTPUT_USD_PER_1M=2.5

# ---------- Fast-path Parser ----------
PROCESSING_FORCE_FALLBACK=false
FASTPATH_MIN_CONFIDENCE=0.9
FASTPATH_MIN_QUESTIONS=1
FASTPATH_MIN_QUESTION_CHARS=10

# ---------- Other ----------
# CONTEXT7_API_KEY=your-key-here
